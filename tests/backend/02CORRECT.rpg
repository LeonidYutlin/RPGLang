prim main() {
  note | hit is -
  note | unite is +
  note | empower is *
  out(#mage 0 #warrior hit #mage 0CC);
  out(0X empower 0V #warrior hit #mage 0V);
  out(0X #priest unite #mage 0C);

  note | shatter is division
  out(0XX #warlock shatter #mage 0II);
  note | shadow is unary -
  out(#priest shadow #mage 0XX #warlock shatter #mage 0X);
  note | <push is logical shift left
  out(0I #warrior <push #mage 0III);
  note | push> is logical shift right
  out(0X #warrior push> #mage 0II);

  note | this is just 15
  out(#priest shadow shadow #mage 0VVV);

  note | rout (Radixed Out): print first argument as an unsigned number 
  note | in base-n, where n is second argument(must be 1-36)
  note | also prints a newline, like out()
  rout(0IXX; 0XX);
  exit(0I);
}
